---
import { Icon } from "astro-icon/components"

import { SITE_TITLE } from "@data/consts"
---



<header class="content-grid">
  <div id="logo" aria-hidden>
    <Icon name="nova" width="1em" height="1em" />
    <span class="name">{SITE_TITLE}</span>
  </div>
</header>



<style lang="scss">
  header {
    margin-block: 4.8rem 7.2rem;
  }

  #logo {
    display: flex;
    align-items: center;
    gap: .8rem;
    font-size: 240%;
    color: var(--grape);

    .name {
      background-color: var(--primary);
      background-image: var(--lemonade-gradient);
      background-clip: text;
      font-size: 60%;
      font-weight: bolder;
      color: transparent;
    }
  }
</style>
